{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:Converse",
        "bedrock:ConverseStream",
        "eks:Describe*",
        "eks:List*",
        "ec2:Describe*",
        "ec2:Get*",
        "iam:Get*",
        "iam:List*",
        "sts:GetCallerIdentity",
        "cloudformation:Describe*",
        "cloudformation:List*",
        "cloudformation:Get*",
        "autoscaling:Describe*",
        "elasticloadbalancing:Describe*",
        "logs:Describe*",
        "logs:Get*",
        "logs:List*",
        "logs:FilterLogEvents",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*"
      ],
      "Resource": "*"
    }
  ]
}
